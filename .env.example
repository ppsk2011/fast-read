# Copy this file to .env and fill in your own values.
# Vite only exposes variables prefixed with VITE_ to the browser.

# GoatCounter analytics (free at https://www.goatcounter.com)
# Sign up, create a site, and paste your site code here (e.g. "paceread").
# Your stats will be at https://<VITE_GOATCOUNTER_SITE_CODE>.goatcounter.com
VITE_GOATCOUNTER_SITE_CODE=

# Feedback form URL — the Google Form is already hardcoded in FeedbackButton.tsx.
# Override here only if you replace it with a different form.
VITE_FEEDBACK_FORM_URL=https://forms.gle/dCBSTs4SjvhmA3Zh6

# Supabase — required for user authentication and cross-device sync.
# Leave blank to run the app in local-only mode (no auth, no sync).
# See docs/SUPABASE_SETUP.md for setup instructions.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
